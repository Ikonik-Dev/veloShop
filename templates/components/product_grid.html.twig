{#
  Product grid component
  @param string title    — titre de la section
  @param string id       — ancre HTML
  @param array  products — liste de {name, description, image}
#}
{% set products = products|default([]) %}

<div class="bg-gray-50 border-t">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		{% if title is defined and title %}
			<h2 {% if id is defined %} id="{{ id }}" {% endif %} class="text-2xl font-bold mb-6">{{ title }}</h2>
		{% endif %}
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
			{% for product in products %}
				{% include 'components/ui/card.html.twig' with {
          title: product.name,
          description: product.description,
          image: product.image|default(null)
        } %}
			{% endfor %}
		</div>
	</div>
</div>
