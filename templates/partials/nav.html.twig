<nav x-data="{ open: false }" class="bg-white shadow-sm">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between h-16 items-center">
			<a href="{{ path('app_home') }}" class="flex items-center gap-3">
				<div class="w-10 h-10 bg-gradient-to-br from-primary to-accent text-white rounded-full flex items-center justify-center font-semibold">RB</div>
				<span class="font-semibold text-lg">Ramesh Bikes</span>
			</a>

			<div class="hidden md:flex items-center gap-6">
				<a href="{{ path('app_products') }}" class="text-gray-700 hover:text-primary">Produits</a>
				<a href="{{ path('app_solutions') }}" class="text-gray-700 hover:text-primary">Solutions</a>
				<a href="{{ path('app_enterprise') }}" class="text-gray-700 hover:text-primary">Entreprise</a>
				<a href="{{ path('app_shop') }}" class="px-4 py-2 bg-primary text-white rounded-md hover:opacity-95">Boutique</a>
				
				{% if is_granted('ROLE_ADMIN') %}
					<a href="{{ path('admin') }}" class="text-gray-700 hover:text-primary text-sm"><span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>Admin</span></a>
				{% endif %}
				
				{% if app.user %}
					<div class="h-8 border-l border-gray-200"></div>
					<div x-data="{ userMenuOpen: false }" class="relative">
						<button @click="userMenuOpen = !userMenuOpen" class="flex items-center gap-2 text-gray-700 hover:text-primary">
							<div class="w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center text-sm font-semibold">
								{{ app.user.email|first|upper }}
							</div>
							<span class="text-sm">{{ app.user.email }}</span>
						</button>
						<div x-show="userMenuOpen" @click.outside="userMenuOpen = false" x-transition class="absolute right-0 mt-2 w-48 bg-white shadow-lg rounded-md z-50">
							<a href="#" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 text-sm">Mon Profil</a>
							<a href="{{ path('app_logout') }}" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 text-sm border-t">Déconnexion</a>
						</div>
					</div>
				{% else %}
					<div class="h-8 border-l border-gray-200"></div>
					<a href="{{ path('app_login') }}" class="text-gray-700 hover:text-primary text-sm">Connexion</a>
					<a href="{{ path('app_register') }}" class="px-4 py-2 bg-accent text-white rounded-md hover:opacity-95 text-sm">S'inscrire</a>
				{% endif %}
			</div>

			<div class="md:hidden">
				<button @click="open = !open" class="p-2 rounded-md bg-gray-100">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
					</svg>
				</button>
			</div>
		</div>
	</div>

	<div x-show="open" x-transition class="md:hidden bg-white border-t">
		<div class="px-4 pt-3 pb-4 space-y-1">
			<a href="{{ path('app_products') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700">Produits</a>
			<a href="{{ path('app_solutions') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700">Solutions</a>
			<a href="{{ path('app_enterprise') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700">Entreprise</a>
			<a href="{{ path('app_shop') }}" class="block px-3 py-2 rounded-md text-base font-medium text-white bg-primary">Boutique</a>
			
			<div class="border-t pt-3 mt-3">
				{% if app.user %}
					<div class="px-3 py-2 text-sm text-gray-700 font-medium">{{ app.user.email }}</div>
					{% if is_granted('ROLE_ADMIN') %}
						<a href="{{ path('admin') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700">Admin</a>
					{% endif %}
					<a href="#" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700">Mon Profil</a>
					<a href="{{ path('app_logout') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700">Déconnexion</a>
				{% else %}
					<a href="{{ path('app_login') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700">Connexion</a>
					<a href="{{ path('app_register') }}" class="block px-3 py-2 rounded-md text-base font-medium text-white bg-accent">S'inscrire</a>
				{% endif %}
			</div>
		</div>
	</div>
</nav>
