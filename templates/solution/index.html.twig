{% extends 'base.html.twig' %}

{% block title %}Solutions — Ramesh Bikes
{% endblock %}

{% block body %}
	{# === Hero solutions === #}
	<section class="bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
			<div class="max-w-2xl">
				{% include 'components/ui/badge.html.twig' with { text: 'Solutions sur mesure' } %}
				<h1 class="mt-4 text-4xl font-extrabold tracking-tight sm:text-5xl">Des solutions pour chaque usage</h1>
				<p class="mt-4 text-lg text-gray-600">Amateur, pro ou institution — nous adaptons notre offre à vos besoins spécifiques.</p>
			</div>
		</div>
	</section>

	{# === Personas === #}
	<section class="bg-gray-50 border-t">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<h2 class="text-2xl font-bold mb-8">Pour qui ?</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{% for sol in [
					{ title: 'Particuliers et amateurs', desc: 'Trouvez le vélo qui correspond à votre pratique, que ce soit pour le loisir, le vélotaf ou le sport du dimanche. Accompagnement personnalisé et financement flexible.', icon: '🚴' },
					{ title: 'Cyclistes compétiteurs', desc: 'Matériel de compétition, fitting biomécanique, options aéro et suivi technique dédié. Partenariats clubs et équipes.', icon: '🏆' },
					{ title: 'Flottes entreprises', desc: 'Programmes de mobilité douce pour vos collaborateurs. Leasing, maintenance incluse, et reporting d\'usage.', icon: '🏢' },
					{ title: 'Collectivités et institutions', desc: 'Appels d\'offres, flottes vélos partagés, stations de réparation. Solutions clé en main pour la mobilité publique.', icon: '🏛️' }
				] %}
					<div class="bg-white rounded-lg shadow p-6">
						<div class="text-3xl mb-3">{{ sol.icon }}</div>
						<h3 class="font-semibold text-lg">{{ sol.title }}</h3>
						<p class="text-sm text-gray-600 mt-2">{{ sol.desc }}</p>
					</div>
				{% endfor %}
			</div>
		</div>
	</section>

	{# === Services === #}
	<section class="bg-white border-t">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<h2 class="text-2xl font-bold mb-8">Services inclus</h2>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
				{% for svc in [
					{ title: 'Fitting professionnel', subtitle: 'Analyse posturale et ajustement sur mesure.' },
					{ title: 'Maintenance premium', subtitle: 'Révisions planifiées, interventions rapides.' },
					{ title: 'Garantie étendue', subtitle: 'Cadre à vie, composants 3 ans.' }
				] %}
					{% include 'components/ui/feature_pill.html.twig' with { title: svc.title, subtitle: svc.subtitle } %}
				{% endfor %}
			</div>
		</div>
	</section>
{% endblock %}
