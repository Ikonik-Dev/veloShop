<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><defs><linearGradient id=%22grad%22 x1=%220%25%22 y1=%220%25%22 x2=%22100%25%22 y2=%22100%25%22><stop offset=%220%25%22 style=%22stop-color:%232563eb%22/><stop offset=%22100%25%22 style=%22stop-color:%23fb923c%22/></linearGradient></defs><rect width=%22128%22 height=%22128%22 fill=%22url(%23grad)%22/><text x=%2264%22 y=%2282%22 font-family=%22Arial, sans-serif%22 font-size=%2256%22 font-weight=%22800%22 fill=%22%23ffffff%22 text-anchor=%22middle%22 dominant-baseline=%22middle%22>RB</text></svg>">
		{% block stylesheets %}
			{# En dev : Vite sert les assets via HMR. En prod : fichiers buildés dans public/build/ #}
			{% if app.debug %}
				<script type="module" src="http://localhost:5173/@vite/client"></script>
				<script type="module" src="http://localhost:5173/assets/main.js"></script>
			{% else %}
				<link rel="stylesheet" href="{{ asset('build/assets/main.css') }}">
			{% endif %}
		{% endblock %}

		{% block javascripts %}
			{% if not app.debug %}
				<script type="module" src="{{ asset('build/assets/main.js') }}"></script>
			{% endif %}
		{% endblock %}
	</head>
	<body class="bg-gray-50 text-gray-800">
		{% include 'partials/nav.html.twig' %}

		<main style="min-height: 70vh;">
{% block body %}{% endblock %}
		</main>

			{% include 'partials/footer.html.twig' %}
		</body>
	</html>
