{% extends 'base.html.twig' %}

{% block title %}Inscription — Ramesh Bikes{% endblock %}

{% block body %}
<section class="py-16">
	<div class="max-w-md mx-auto px-4">
		<div class="bg-white rounded-lg shadow p-8">
			<div class="text-center mb-8">
				<div class="w-14 h-14 bg-gradient-to-br from-primary to-accent text-white rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">RB</div>
				<h1 class="text-2xl font-bold">Créer un compte</h1>
				<p class="text-gray-500 text-sm mt-1">Rejoignez la communauté Ramesh Bikes</p>
			</div>

			{% for flash_error in app.flashes('verify_email_error') %}
				<div class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 rounded-md text-sm" role="alert">
					{{ flash_error }}
				</div>
			{% endfor %}

			{{ form_errors(registrationForm) }}

			{{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}
				<div>
					{{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
					{{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition', 'placeholder': 'votre@email.com'}}) }}
					{{ form_errors(registrationForm.email) }}
				</div>

				<div>
					{{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
					{{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition'}}) }}
					{{ form_errors(registrationForm.plainPassword) }}
				</div>

				<div class="flex items-start gap-2">
					{{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'mt-1 rounded border-gray-300 text-primary focus:ring-primary'}}) }}
					{{ form_label(registrationForm.agreeTerms, 'J\'accepte les conditions d\'utilisation', {'label_attr': {'class': 'text-sm text-gray-600'}}) }}
				</div>
				{{ form_errors(registrationForm.agreeTerms) }}

				<button type="submit" class="w-full px-6 py-3 bg-primary text-white rounded-lg font-semibold hover:opacity-95 transition">
					Créer mon compte
				</button>
			{{ form_end(registrationForm) }}

			<p class="text-center text-sm text-gray-500 mt-6">
				Déjà inscrit ?
				<a href="{{ path('app_login') }}" class="text-primary font-medium hover:underline">Se connecter</a>
			</p>
		</div>
	</div>
</section>
{% endblock %}
