{% extends 'base.html.twig' %}

{% block title %}Connexion — Ramesh Bikes{% endblock %}

{% block body %}
<section class="py-16">
	<div class="max-w-md mx-auto px-4">
		<div class="bg-white rounded-lg shadow p-8">
			<div class="text-center mb-8">
				<div class="w-14 h-14 bg-gradient-to-br from-primary to-accent text-white rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">RB</div>
				<h1 class="text-2xl font-bold">Connexion</h1>
				<p class="text-gray-500 text-sm mt-1">Accédez à votre espace Ramesh Bikes</p>
			</div>

			{% if error %}
				<div class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 rounded-md text-sm">
					{{ error.messageKey|trans(error.messageData, 'security') }}
				</div>
			{% endif %}

			{% if app.user %}
				<div class="mb-6 p-3 bg-blue-50 border border-blue-200 text-blue-700 rounded-md text-sm">
					Vous êtes connecté en tant que {{ app.user.userIdentifier }}.
					<a href="{{ logout_path() }}" class="underline font-medium">Se déconnecter</a>
				</div>
			{% endif %}

			<form method="post" class="space-y-5">
				<div>
					<label for="inputEmail" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
					<input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" required autofocus
						class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition">
				</div>

				<div>
					<label for="inputPassword" class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
					<input type="password" name="password" id="inputPassword" autocomplete="current-password" required
						class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition">
				</div>

				<input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

				<div class="flex items-center justify-between">
					<label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
						<input type="checkbox" name="_remember_me" class="rounded border-gray-300 text-primary focus:ring-primary">
						Se souvenir de moi
					</label>
				</div>

				<button type="submit" class="w-full px-6 py-3 bg-primary text-white rounded-lg font-semibold hover:opacity-95 transition">
					Se connecter
				</button>
			</form>

			<p class="text-center text-sm text-gray-500 mt-6">
				Pas encore de compte ?
				<a href="{{ path('app_register') }}" class="text-primary font-medium hover:underline">S'inscrire</a>
			</p>
		</div>
	</div>
</section>
{% endblock %}
